{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-ordin.srv-jvt.com"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-apk": {
      "distribution": "internal",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-ordin.srv-jvt.com"
      },
      "android": {
        "buildType": "apk"
      }
    }
  }
}

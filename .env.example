# EXPO_PUBLIC_API_URL é usada pelo app para acessar a API.
# Em APK/produção, use uma URL pública HTTPS do backend.

# Desenvolvimento — rede local (npm start gera .env.development.local com seu IP)
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3333

# Desenvolvimento — API na VPS (npm start NÃO sobrescreve se for https://)
EXPO_PUBLIC_API_URL=https://api-ordin.srv-jvt.com

# Atalho: npm run start:remote (só Expo, sem backend local)
